#!/bin/bash
# Docklaude - Container wrapper for Claude Code
# Provides sandboxing by limiting file access to a workspace folder

set -e

# Configuration
IMAGE_NAME="docklaude"
CONTAINER_NAME="docklaude-$$"

# Get absolute path of workspace (current directory)
WORKSPACE="$(pwd)"
DOCKLAUDE_DIR="${WORKSPACE}/.docklaude"

# Host Claude directory (for credentials/settings)
HOST_CLAUDE_DIR="${HOME}/.claude"
HOST_CLAUDE_JSON="${HOME}/.claude.json"

# Check if host ~/.claude exists
if [ ! -d "${HOST_CLAUDE_DIR}" ]; then
    echo "Error: ${HOST_CLAUDE_DIR} does not exist."
    echo "Please run 'claude login' first to set up your Claude credentials."
    exit 1
fi

# Check if host ~/.claude.json exists
if [ ! -f "${HOST_CLAUDE_JSON}" ]; then
    echo "Error: ${HOST_CLAUDE_JSON} does not exist."
    echo "Please run 'claude login' first to set up your Claude configuration."
    exit 1
fi

# Create .docklaude directory structure
mkdir -p "${DOCKLAUDE_DIR}/.claude"

# Container-side Claude config directory
CONTAINER_CLAUDE_DIR="${DOCKLAUDE_DIR}/.claude"
CONTAINER_CLAUDE_JSON="${DOCKLAUDE_DIR}/.claude.json"

# Copy credentials from host if they don't exist in container's .docklaude
# This ensures host files remain untouched while container has its own copies
if [ ! -f "${CONTAINER_CLAUDE_DIR}/.credentials.json" ]; then
    cp "${HOST_CLAUDE_DIR}/.credentials.json" "${CONTAINER_CLAUDE_DIR}/.credentials.json"
    chmod 600 "${CONTAINER_CLAUDE_DIR}/.credentials.json"
fi

# Copy .claude.json config file if it doesn't exist (goes in HOME, not .claude/)
if [ ! -f "${CONTAINER_CLAUDE_JSON}" ]; then
    cp "${HOST_CLAUDE_JSON}" "${CONTAINER_CLAUDE_JSON}"
    chmod 600 "${CONTAINER_CLAUDE_JSON}"
fi

# Ensure the image exists
if ! docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1; then
    echo "Image '${IMAGE_NAME}' not found. Building..."
    SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
fi

# Run the container with:
# - Writable mount of .docklaude/.claude (container's copy of config)
# - Read-write mount of workspace
# - Userspace mode (--user) to ensure files are owned by the host user
# - Pass through all arguments to claude

docker run --rm -it --init \
    --name "${CONTAINER_NAME}" \
    --user "$(id -u):$(id -g)" \
    -v "${WORKSPACE}:/workspace" \
    -v "${CONTAINER_CLAUDE_DIR}:/home/claude/.claude" \
    -v "${CONTAINER_CLAUDE_JSON}:/home/claude/.claude.json" \
    -e HOME=/home/claude \
    --workdir /workspace \
    "${IMAGE_NAME}" \
    "$@"
