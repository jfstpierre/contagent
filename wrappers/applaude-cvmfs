#!/bin/bash
# applaude-cvmfs - Apptainer wrapper for Claude Code (DRAC/Alliance cluster variant)
# Provides sandboxing by limiting file access to a workspace folder.
# Python and other software come from the CVMFS-mounted module stack,
# not from the SIF image. Tracks loaded modules in .applaude/modules.

set -e

# Configuration
SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"
# shellcheck source=lib/context.sh
source "${SCRIPT_DIR}/lib/context.sh"
SIF_IMAGE="${CONTAGENT_DIR:-${HOME}/.contagent}/apptainer-cvmfs.sif"

# Get absolute path of workspace (current directory)
WORKSPACE="$(pwd)"
APPLAUDE_DIR="${WORKSPACE}/.contagent/applaude"
CONTAINER_HOME="${APPLAUDE_DIR}/home"

# Host Claude directory (for credentials/settings)
HOST_CLAUDE_DIR="${HOME}/.claude"
HOST_CLAUDE_JSON="${HOME}/.claude.json"

# Check if host ~/.claude exists
if [ ! -d "${HOST_CLAUDE_DIR}" ]; then
  echo "Error: ${HOST_CLAUDE_DIR} does not exist."
  echo "Please run 'claude login' first to set up your Claude credentials."
  exit 1
fi

# Check if host ~/.claude.json exists
if [ ! -f "${HOST_CLAUDE_JSON}" ]; then
  echo "Error: ${HOST_CLAUDE_JSON} does not exist."
  echo "Please run 'claude login' first to set up your Claude configuration."
  exit 1
fi

if [ ! -f "${SIF_IMAGE}" ]; then
  echo "Error: SIF not found: ${SIF_IMAGE}"
  echo "Run 'contagent' first to build the container image."
  exit 1
fi

# Persistent per-workspace home (Claude history, project memory, etc. — not sensitive).
mkdir -p "${CONTAINER_HOME}/.claude"
mkdir -p "${CONTAINER_HOME}/.ssh"

# Apptainer (unprivileged) does not support layering a --bind on top of --home,
# so we build a merged home: existing session state + fresh credentials.
# The merged home is used as --home; on exit its contents are synced back to
# CONTAINER_HOME with credentials stripped, keeping the workspace clean.
RUNTIME_DIR="${CONTAGENT_DIR:-${HOME}/.contagent}/runtime"
mkdir -p "${RUNTIME_DIR}"
MERGED_HOME=$(mktemp -d "${RUNTIME_DIR}/contagent-XXXXXX")
chmod 700 "${MERGED_HOME}"

cp -a "${CONTAINER_HOME}/." "${MERGED_HOME}/" 2>/dev/null || true
inject_ssh_config_apptainer "${WORKSPACE}" "${MERGED_HOME}"
mkdir -p "${MERGED_HOME}/.claude"
cp "${HOST_CLAUDE_DIR}/.credentials.json" "${MERGED_HOME}/.claude/.credentials.json"
chmod 600 "${MERGED_HOME}/.claude/.credentials.json"
cp "${HOST_CLAUDE_JSON}" "${MERGED_HOME}/.claude.json"
chmod 600 "${MERGED_HOME}/.claude.json"

_contagent_cleanup() {
  cp -a "${MERGED_HOME}/." "${CONTAINER_HOME}/" 2>/dev/null || true
  rm -f "${CONTAINER_HOME}/.claude/.credentials.json" "${CONTAINER_HOME}/.claude.json"
  rm -rf "${MERGED_HOME}"
  contagent_ssh_agent_cleanup
}
trap '_contagent_cleanup' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

# Reconcile loaded modules against saved list
reconcile_cvmfs_modules "${APPLAUDE_DIR}/modules"

# Load the Apptainer module recorded by contagent, if any
load_apptainer_module

# Build bind args: always bind workspace; bind /cvmfs if present on host.
BIND_ARGS=("--bind" "${WORKSPACE}:/workspace")
[ -d "/cvmfs" ] && BIND_ARGS+=("--bind" "/cvmfs:/cvmfs")

# Parse .contagent/mounts for extra bind mounts
init_mounts_file "${WORKSPACE}"
parse_mounts_apptainer "${WORKSPACE}" BIND_ARGS
forward_ssh_agent_apptainer "${WORKSPACE}" BIND_ARGS

# Generate container context file and install Claude skills
generate_context_file "${WORKSPACE}" "applaude-cvmfs" "${APPLAUDE_DIR}/modules"
install_claude_skills "${CONTAINER_HOME}"

# Propagate PATH with claude's install dir prepended.
# Also include $HOME/.local/bin (= CONTAINER_HOME/.local/bin) so claude's
# startup check doesn't warn about ~/.local/bin not being in PATH.
# All other module-set env vars (LD_LIBRARY_PATH, PYTHONPATH, EBROOT*, etc.)
# flow into the container automatically via Apptainer's default host-env inheritance.
export APPTAINERENV_PATH="/root/.local/bin:${MERGED_HOME}/.local/bin:${PATH}"

# Run the container with:
# --home: merged home (session state + credentials; never persisted back with credentials)
# --bind: mount workspace read-write, plus /cvmfs if available, plus .contagent/mounts
# --workdir: start in /workspace
# Pass through all arguments to claude
apptainer run \
  --home "${MERGED_HOME}" \
  "${BIND_ARGS[@]}" \
  --workdir /workspace \
  "${SIF_IMAGE}" \
  --append-system-prompt-file /workspace/.contagent/context.md \
  "$@"
