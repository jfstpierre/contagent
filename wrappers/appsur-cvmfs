#!/bin/bash
# appsur-cvmfs - Apptainer wrapper for Cursor agent (DRAC/Alliance cluster variant)
# Provides sandboxing by limiting file access to a workspace folder.
# Python and other software come from the CVMFS-mounted module stack,
# not from the SIF image. Tracks loaded modules in .appsur/modules.

set -e

# Configuration
SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
SIF_IMAGE="${CONTAGENT_DIR:-${HOME}/.contagent}/apptainer-cvmfs.sif"

# Get absolute path of workspace (current directory)
WORKSPACE="$(pwd)"
APPSUR_DIR="${WORKSPACE}/.contagent/appsur"
CONTAINER_HOME="${APPSUR_DIR}/home"

# Host Cursor directories (for credentials/settings)
HOST_CURSOR_AUTH="${HOME}/.config/cursor/auth.json"
HOST_CURSOR_CONFIG="${HOME}/.cursor/cli-config.json"

# Check if host auth.json exists
if [ ! -f "${HOST_CURSOR_AUTH}" ]; then
  echo "Error: ${HOST_CURSOR_AUTH} does not exist."
  echo "Please run 'cursor login' first to set up your Cursor credentials."
  exit 1
fi

# Check if host cli-config.json exists
if [ ! -f "${HOST_CURSOR_CONFIG}" ]; then
  echo "Error: ${HOST_CURSOR_CONFIG} does not exist."
  echo "Please run 'cursor login' first to set up your Cursor configuration."
  exit 1
fi

if [ ! -f "${SIF_IMAGE}" ]; then
  echo "Error: SIF not found: ${SIF_IMAGE}"
  echo "Run 'contagent' first to build the container image."
  exit 1
fi

# Persistent per-workspace home (not sensitive).
mkdir -p "${CONTAINER_HOME}/.config/cursor" "${CONTAINER_HOME}/.cursor"

# Apptainer (unprivileged) does not support layering a --bind on top of --home,
# so we build a merged home: existing session state + fresh credentials.
RUNTIME_DIR="${CONTAGENT_DIR:-${HOME}/.contagent}/runtime"
mkdir -p "${RUNTIME_DIR}"
MERGED_HOME=$(mktemp -d "${RUNTIME_DIR}/contagent-XXXXXX")
chmod 700 "${MERGED_HOME}"

cp -a "${CONTAINER_HOME}/." "${MERGED_HOME}/" 2>/dev/null || true
mkdir -p "${MERGED_HOME}/.config/cursor" "${MERGED_HOME}/.cursor"
cp "${HOST_CURSOR_AUTH}" "${MERGED_HOME}/.config/cursor/auth.json"
chmod 600 "${MERGED_HOME}/.config/cursor/auth.json"
cp "${HOST_CURSOR_CONFIG}" "${MERGED_HOME}/.cursor/cli-config.json"
chmod 600 "${MERGED_HOME}/.cursor/cli-config.json"

_contagent_cleanup() {
  cp -a "${MERGED_HOME}/." "${CONTAINER_HOME}/" 2>/dev/null || true
  rm -f "${CONTAINER_HOME}/.config/cursor/auth.json" \
        "${CONTAINER_HOME}/.cursor/cli-config.json"
  rm -rf "${MERGED_HOME}"
}
trap '_contagent_cleanup' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

# Ensure lmod's module function is available
ensure_module() {
  if ! type module >/dev/null 2>&1; then
    for lmod_init in \
      /cvmfs/soft.computecanada.ca/nix/var/nix/profiles/16.09/lmod/lmod/init/bash \
      /etc/profile.d/lmod.sh \
      /usr/share/lmod/lmod/init/bash; do
      [ -f "$lmod_init" ] && { source "$lmod_init"; return 0; }
    done
    return 1
  fi
}

# Load modules listed in a file
load_modules_from_file() {
  local file="$1"
  if ! ensure_module; then
    echo "Warning: 'module' unavailable — skipping module loading."
    echo "Ensure lmod is initialized before running appsur-cvmfs."
    return
  fi
  module purge
  while IFS= read -r mod || [ -n "$mod" ]; do
    [[ -z "$mod" || "$mod" =~ ^[[:space:]]*# ]] && continue
    echo "Loading module: $mod"
    module load "$mod"
  done < "$file"
}

# Get currently loaded modules (one per line, in lmod order)
get_loaded_modules() {
  echo "${LOADEDMODULES:-}" | tr ':' '\n' | grep -v '^$'
}

# Handle .appsur/modules tracking
MODULES_FILE="${APPSUR_DIR}/modules"

CURRENT_MODULES="$(get_loaded_modules)"

if [ ! -f "${MODULES_FILE}" ]; then
  # First execution: save currently loaded modules
  echo "${CURRENT_MODULES}" > "${MODULES_FILE}"
  echo "Saved loaded modules to ${MODULES_FILE}"
else
  # Compare currently loaded modules with saved ones (order-independent)
  SAVED_MODULES="$(cat "${MODULES_FILE}")"
  CURRENT_SORTED="$(echo "${CURRENT_MODULES}" | sort)"
  SAVED_SORTED="$(echo "${SAVED_MODULES}" | sort)"

  if [ "${CURRENT_SORTED}" != "${SAVED_SORTED}" ]; then
    echo "Loaded modules differ from ${MODULES_FILE}:"
    echo "  Currently loaded: $(echo "${CURRENT_MODULES}" | tr '\n' ' ')"
    echo "  In modules file:  $(echo "${SAVED_MODULES}" | tr '\n' ' ')"
    while true; do
      read -r -p "(C)hange loaded modules to match file, (U)pdate file with current modules, (I)gnore? [C/U/I]: " choice
      case "${choice}" in
        [Cc])
          load_modules_from_file "${MODULES_FILE}"
          break
          ;;
        [Uu])
          echo "${CURRENT_MODULES}" > "${MODULES_FILE}"
          echo "Updated ${MODULES_FILE}"
          break
          ;;
        [Ii])
          break
          ;;
        *)
          echo "Please enter C, U, or I."
          ;;
      esac
    done
  fi
fi

# Load the Apptainer module recorded by contagent, if any
SETTINGS_FILE="${CONTAGENT_DIR:-${HOME}/.contagent}/settings"
if [ -f "${SETTINGS_FILE}" ]; then
  APPTAINER_MODULE="$(grep '^APPTAINER_MODULE=' "${SETTINGS_FILE}" | cut -d= -f2-)"
  if [ -n "${APPTAINER_MODULE:-}" ]; then
    if ensure_module; then
      module load "${APPTAINER_MODULE}"
    else
      echo "Warning: lmod unavailable — could not load Apptainer module '${APPTAINER_MODULE}'."
    fi
  fi
fi

# Build bind args: always bind workspace; bind /cvmfs if present on host.
BIND_ARGS=("--bind" "${WORKSPACE}:/workspace")
[ -d "/cvmfs" ] && BIND_ARGS+=("--bind" "/cvmfs:/cvmfs")

# Parse .contagent/mounts for extra bind mounts
# Format: host_path:container_path[:mode]  (mode: ro or rw, default: ro)
MOUNTS_FILE="${WORKSPACE}/.contagent/mounts"

# Create .contagent/mounts on first run with commented instructions
if [ ! -f "${MOUNTS_FILE}" ]; then
  mkdir -p "${WORKSPACE}/.contagent"
  cat > "${MOUNTS_FILE}" << 'MOUNTS_TEMPLATE'
# Extra bind mounts for contagent containers
#
# To mount additional host paths into the container, add entries below, one per line:
#   host_path:container_path[:mode]
#
# mode is optional; defaults to "ro" (read-only). Use "rw" for read-write access.
# Tilde (~) is expanded to your home directory ($HOME).
# Paths that do not exist on the host are skipped with a warning.
# Lines starting with # are comments and are ignored.
#
# Examples:
#   /data/shared:/data:ro
#   ~/models:/models:ro
#   /scratch/myproject:/scratch:rw
MOUNTS_TEMPLATE
  echo "Note: .contagent/mounts created."
  echo "  Add extra bind mounts for the container by editing:"
  echo "    ${MOUNTS_FILE}"
  echo "  Format: host_path:container_path[:mode]  (mode: ro or rw, default: ro)"
  echo "  Example: /data/shared:/data:ro"
  echo ""
fi

if [ -f "${MOUNTS_FILE}" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    IFS=: read -r host_path container_path mode <<< "$line"
    if [ -z "${host_path}" ] || [ -z "${container_path}" ]; then
      echo "Warning: invalid entry in ${MOUNTS_FILE}: ${line}"
      continue
    fi
    mode="${mode:-ro}"
    if [[ "${mode}" != "ro" && "${mode}" != "rw" ]]; then
      echo "Warning: unknown mode '${mode}' in ${MOUNTS_FILE} (use ro or rw), defaulting to ro"
      mode="ro"
    fi
    host_path="${host_path/#\~/$HOME}"
    if [ ! -e "${host_path}" ]; then
      echo "Warning: mount source does not exist: ${host_path} (skipping)"
      continue
    fi
    BIND_ARGS+=("--bind" "${host_path}:${container_path}:${mode}")
  done < "${MOUNTS_FILE}"
fi

# Propagate PATH with cursor-agent's install dir prepended.
# Also include $HOME/.local/bin (= CONTAINER_HOME/.local/bin) so startup
# checks don't warn about ~/.local/bin not being in PATH.
# All other module-set env vars (LD_LIBRARY_PATH, PYTHONPATH, EBROOT*, etc.)
# flow into the container automatically via Apptainer's default host-env inheritance.
export APPTAINERENV_PATH="/root/.local/bin:${MERGED_HOME}/.local/bin:${PATH}"

# Run cursor-agent with:
# --home: merged home (session state + credentials; never persisted back with credentials)
# --bind: mount workspace read-write, plus /cvmfs if available, plus .contagent/mounts
# --workdir: start in /workspace
# Pass through all arguments to cursor-agent
apptainer exec \
  --home "${MERGED_HOME}" \
  "${BIND_ARGS[@]}" \
  --workdir /workspace \
  "${SIF_IMAGE}" \
  cursor-agent "$@"
