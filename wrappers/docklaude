#!/bin/bash
# Docklaude - Container wrapper for Claude Code
# Provides sandboxing by limiting file access to a workspace folder

set -e

# shellcheck source=lib/common.sh
source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/lib/common.sh"

# Configuration
IMAGE_NAME="docklaude"
CONTAINER_NAME="docklaude-$$"

# Get absolute path of workspace (current directory)
WORKSPACE="$(pwd)"
DOCKLAUDE_DIR="${WORKSPACE}/.contagent/docklaude"
CONTAINER_HOME="${DOCKLAUDE_DIR}/home"

# Host Claude directory (for credentials/settings)
HOST_CLAUDE_DIR="${HOME}/.claude"
HOST_CLAUDE_JSON="${HOME}/.claude.json"

# Check if host ~/.claude exists
if [ ! -d "${HOST_CLAUDE_DIR}" ]; then
    echo "Error: ${HOST_CLAUDE_DIR} does not exist."
    echo "Please run 'claude login' first to set up your Claude credentials."
    exit 1
fi

# Check if host ~/.claude.json exists
if [ ! -f "${HOST_CLAUDE_JSON}" ]; then
    echo "Error: ${HOST_CLAUDE_JSON} does not exist."
    echo "Please run 'claude login' first to set up your Claude configuration."
    exit 1
fi

# Migrate old structure (.contagent/docklaude/.claude/ → home/.claude/) if needed.
# The old layout mounted .claude/ directly; the new layout mounts a full home dir.
if [ -d "${DOCKLAUDE_DIR}/.claude" ] && [ ! -d "${CONTAINER_HOME}/.claude" ]; then
    mkdir -p "${CONTAINER_HOME}"
    mv "${DOCKLAUDE_DIR}/.claude" "${CONTAINER_HOME}/.claude"
fi

# Credentials live in ~/.contagent (private, never in the shareable workspace).
# Copied fresh every launch so token refreshes from previous sessions are picked up.
CRED_DIR="${CONTAGENT_DIR:-${HOME}/.contagent}/claude/creds"
mkdir -p "${CRED_DIR}"
cp "${HOST_CLAUDE_DIR}/.credentials.json" "${CRED_DIR}/.credentials.json"
chmod 600 "${CRED_DIR}/.credentials.json"
cp "${HOST_CLAUDE_JSON}" "${CRED_DIR}/.claude.json"
chmod 600 "${CRED_DIR}/.claude.json"

# Persistent per-workspace home (Claude history, project memory, etc. — not sensitive).
# Empty stubs ensure Docker treats these as files rather than creating directories.
# The `: >` also clears any credentials left there by an older version of this script.
mkdir -p "${CONTAINER_HOME}/.claude"
: > "${CONTAINER_HOME}/.claude/.credentials.json"
: > "${CONTAINER_HOME}/.claude.json"

# Ensure the image exists
if ! docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1; then
    echo "Image '${IMAGE_NAME}' not found. Building..."
    SCRIPT_DIR="$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")"
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
fi

# Parse .contagent/mounts for extra bind mounts
EXTRA_BIND_ARGS=()
init_mounts_file "${WORKSPACE}"
parse_mounts_docker "${WORKSPACE}" EXTRA_BIND_ARGS

# Run the container with:
# - Read-write mount of workspace
# - Full per-workspace home (persistent non-sensitive state)
# - Credential files overlaid from CRED_DIR (never stored in workspace)
# - Userspace mode (--user) to ensure files are owned by the host user
# - Extra mounts from .contagent/mounts
# - Pass through all arguments to claude

docker run --rm -it --init \
    --name "${CONTAINER_NAME}" \
    --user "$(id -u):$(id -g)" \
    -v "${WORKSPACE}:/workspace" \
    -v "${CONTAINER_HOME}:/home/claude" \
    -v "${CRED_DIR}/.credentials.json:/home/claude/.claude/.credentials.json" \
    -v "${CRED_DIR}/.claude.json:/home/claude/.claude.json" \
    "${EXTRA_BIND_ARGS[@]}" \
    -e HOME=/home/claude \
    --workdir /workspace \
    "${IMAGE_NAME}" \
    "$@"
