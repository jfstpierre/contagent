#!/bin/bash
# dockbash - Docker wrapper: interactive bash shell in the container

set -e

# shellcheck source=lib/common.sh
source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/lib/common.sh"

# Configuration
IMAGE_NAME="docklaude"
CONTAINER_NAME="dockbash-$$"

# Get absolute path of workspace (current directory)
WORKSPACE="$(pwd)"
DOCKBASH_DIR="${WORKSPACE}/.contagent/dockbash"
CONTAINER_HOME="${DOCKBASH_DIR}/home"

# Create per-workspace home directory structure
mkdir -p "${CONTAINER_HOME}"

# Ensure the image exists
if ! docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1; then
  echo "Image '${IMAGE_NAME}' not found."
  echo "Run 'contagent build' first to build the container image."
  exit 1
fi

# Parse .contagent/mounts for extra bind mounts
EXTRA_BIND_ARGS=()
init_mounts_file "${WORKSPACE}"
parse_mounts_docker "${WORKSPACE}" EXTRA_BIND_ARGS
forward_ssh_agent_docker "${WORKSPACE}" EXTRA_BIND_ARGS
trap 'contagent_ssh_agent_cleanup' EXIT

# Run bash with:
# --entrypoint: override image default to run bash
# --user: run as current user so files are owned by the host user
# -v workspace: mount workspace read-write
# -v home: mount per-workspace state dir as container home
# -e HOME: point HOME at the mounted state dir
# Extra mounts from .contagent/mounts
# --workdir: start in /workspace
docker run --rm -it --init \
  --name "${CONTAINER_NAME}" \
  --entrypoint bash \
  --user "$(id -u):$(id -g)" \
  -v "${WORKSPACE}:/workspace" \
  -v "${CONTAINER_HOME}:/home/bash" \
  "${EXTRA_BIND_ARGS[@]}" \
  -e HOME=/home/bash \
  --workdir /workspace \
  "${IMAGE_NAME}"
